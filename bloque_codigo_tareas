        "# =========================\n",
        "# IMPORTS\n",
        "# =========================\n",
        "\n",
        "import json\n",
        "from datetime import datetime\n",
        "\n",
        "# =========================\n",
        "# DATA\n",
        "# =========================\n",
        "\n",
        "def cargar_tareas():\n",
        "    try:\n",
        "        with open(\"tareas.json\", \"r\") as archivo:\n",
        "            return json.load(archivo)\n",
        "    except:\n",
        "        return []\n",
        "\n",
        "def guardar_tareas(tareas):\n",
        "    with open(\"tareas.json\", \"w\") as archivo:\n",
        "        json.dump(tareas, archivo, indent=4)\n",
        "\n",
        "# =========================\n",
        "# UTILIDADES\n",
        "# =========================\n",
        "\n",
        "def pedir_numero(mensaje):\n",
        "    while True:\n",
        "        valor = input(mensaje)\n",
        "        if valor.isdigit():\n",
        "            return int(valor)\n",
        "        else:\n",
        "            print(\"⚠️ Introduce un número válido\")\n",
        "\n",
        "# =========================\n",
        "# FUNCIONES PRINCIPALES\n",
        "# =========================\n",
        "\n",
        "def añadir_tarea(tareas):\n",
        "\n",
        "    titulo = input(\"Nueva tarea: \").strip()\n",
        "\n",
        "    if titulo == \"\":\n",
        "        print(\"⚠️ La tarea no puede estar vacía\")\n",
        "        return\n",
        "\n",
        "    tarea = {\n",
        "        \"titulo\": titulo,\n",
        "        \"completada\": False,\n",
        "        \"fecha\": datetime.now().strftime(\"%Y-%m-%d\")\n",
        "    }\n",
        "\n",
        "    tareas.append(tarea)\n",
        "\n",
        "    guardar_tareas(tareas)\n",
        "\n",
        "    print(\"✅ Tarea añadida\")\n",
        "\n",
        "def mostrar_tareas(tareas):\n",
        "\n",
        "    if not tareas:\n",
        "        print(\"No hay tareas.\")\n",
        "        return\n",
        "\n",
        "    print(\"\\n📋 LISTA DE TAREAS\")\n",
        "\n",
        "    for i, tarea in enumerate(tareas, start=1):\n",
        "\n",
        "        estado = \"✅\" if tarea[\"completada\"] else \"❌\"\n",
        "\n",
        "        fecha = tarea.get(\"fecha\", \"sin fecha\")\n",
        "\n",
        "        print(i, \"-\", tarea[\"titulo\"], estado, \"|\", fecha)\n",
        "\n",
        "# =========================\n",
        "# CRUD\n",
        "# =========================\n",
        "\n",
        "def completar_tarea(tareas):\n",
        "\n",
        "    if not tareas:\n",
        "        print(\"No hay tareas.\")\n",
        "        return\n",
        "\n",
        "    mostrar_tareas(tareas)\n",
        "\n",
        "    numero = pedir_numero(\"Número de tarea: \")\n",
        "\n",
        "    if 1 <= numero <= len(tareas):\n",
        "\n",
        "        tareas[numero - 1][\"completada\"] = True\n",
        "\n",
        "        guardar_tareas(tareas)\n",
        "\n",
        "        print(\"✅ Tarea completada\")\n",
        "\n",
        "    else:\n",
        "        print(\"Número fuera de rango\")\n",
        "\n",
        "\n",
        "def eliminar_tarea(tareas):\n",
        "\n",
        "    if not tareas:\n",
        "        print(\"No hay tareas.\")\n",
        "        return\n",
        "\n",
        "    mostrar_tareas(tareas)\n",
        "\n",
        "    numero = pedir_numero(\"Número de tarea a eliminar: \")\n",
        "\n",
        "    if 1 <= numero <= len(tareas):\n",
        "\n",
        "        confirmar = input(\"¿Seguro? (s/n): \").lower()\n",
        "\n",
        "        if confirmar == \"s\":\n",
        "\n",
        "            tarea = tareas.pop(numero - 1)\n",
        "\n",
        "            guardar_tareas(tareas)\n",
        "\n",
        "            print(\"🗑️ Eliminada:\", tarea[\"titulo\"])\n",
        "\n",
        "        else:\n",
        "\n",
        "            print(\"Cancelado\")\n",
        "\n",
        "    else:\n",
        "\n",
        "        print(\"Número inválido\")\n",
        "\n",
        "\n",
        "def editar_tarea(tareas):\n",
        "\n",
        "    if not tareas:\n",
        "        print(\"No hay tareas para editar.\")\n",
        "        return\n",
        "\n",
        "    mostrar_tareas(tareas)\n",
        "\n",
        "    numero = pedir_numero(\"Número de tarea a editar: \")\n",
        "\n",
        "    if 1 <= numero <= len(tareas):\n",
        "\n",
        "        nuevo_titulo = input(\"Nuevo título: \").strip()\n",
        "\n",
        "        if nuevo_titulo:\n",
        "\n",
        "            tareas[numero - 1][\"titulo\"] = nuevo_titulo\n",
        "\n",
        "            guardar_tareas(tareas)\n",
        "\n",
        "            print(\"✏️ Tarea actualizada\")\n",
        "\n",
        "    else:\n",
        "\n",
        "        print(\"Número inválido\")\n",
        "\n",
        "# =========================\n",
        "# BUSCAR Y FILTROS\n",
        "# =========================\n",
        "\n",
        "def buscar_tareas(tareas):\n",
        "\n",
        "    texto = input(\"Buscar tarea: \").lower()\n",
        "\n",
        "    resultados = [t for t in tareas if texto in t[\"titulo\"].lower()]\n",
        "\n",
        "    if not resultados:\n",
        "\n",
        "        print(\"No se encontraron tareas\")\n",
        "\n",
        "    else:\n",
        "\n",
        "        print(\"\\n🔍 RESULTADOS\")\n",
        "\n",
        "        for t in resultados:\n",
        "\n",
        "            estado = \"✅\" if t[\"completada\"] else \"❌\"\n",
        "\n",
        "            print(\"-\", t[\"titulo\"], estado)\n",
        "\n",
        "def mostrar_completadas(tareas):\n",
        "\n",
        "    completadas = [t for t in tareas if t[\"completada\"]]\n",
        "\n",
        "    if not completadas:\n",
        "\n",
        "        print(\"No hay tareas completadas.\")\n",
        "\n",
        "    else:\n",
        "\n",
        "        print(\"\\n✅ COMPLETADAS\")\n",
        "\n",
        "        for t in completadas:\n",
        "\n",
        "            print(\"-\", t[\"titulo\"])\n",
        "\n",
        "def mostrar_pendientes(tareas):\n",
        "\n",
        "    pendientes = [t for t in tareas if not t[\"completada\"]]\n",
        "\n",
        "    if not pendientes:\n",
        "\n",
        "        print(\"No hay tareas pendientes.\")\n",
        "\n",
        "    else:\n",
        "\n",
        "        print(\"\\n⏳ PENDIENTES\")\n",
        "\n",
        "        for t in pendientes:\n",
        "\n",
        "            print(\"-\", t[\"titulo\"])\n",
        "\n",
        "# =========================\n",
        "# FUNCIONES EXTRA\n",
        "# =========================\n",
        "\n",
        "def completar_todas(tareas):\n",
        "\n",
        "    if not tareas:\n",
        "        print(\"No hay tareas.\")\n",
        "        return\n",
        "\n",
        "    for tarea in tareas:\n",
        "\n",
        "        tarea[\"completada\"] = True\n",
        "\n",
        "    guardar_tareas(tareas)\n",
        "\n",
        "    print(\"✅ Todas las tareas completadas\")\n",
        "\n",
        "\n",
        "def limpiar_completadas(tareas):\n",
        "\n",
        "    nuevas = [t for t in tareas if not t[\"completada\"]]\n",
        "\n",
        "    eliminadas = len(tareas) - len(nuevas)\n",
        "\n",
        "    tareas[:] = nuevas\n",
        "\n",
        "    guardar_tareas(tareas)\n",
        "\n",
        "    print(f\"🧹 Eliminadas {eliminadas} tareas completadas\")\n",
        "\n",
        "\n",
        "def exportar_tareas(tareas):\n",
        "\n",
        "    with open(\"export_tareas.txt\", \"w\") as archivo:\n",
        "\n",
        "        for t in tareas:\n",
        "\n",
        "            estado = \"✔\" if t[\"completada\"] else \" \"\n",
        "\n",
        "            archivo.write(f\"[{estado}] {t['titulo']}\\n\")\n",
        "\n",
        "    print(\"📁 Tareas exportadas a export_tareas.txt\")\n",
        "\n",
        "# =========================\n",
        "# RESUMEN Y ESTADÍSTICAS\n",
        "# =========================\n",
        "\n",
        "def resumen_tareas(tareas):\n",
        "\n",
        "    total = len(tareas)\n",
        "\n",
        "    completadas = len([t for t in tareas if t[\"completada\"]])\n",
        "\n",
        "    pendientes = total - completadas\n",
        "\n",
        "    print(\"\\n📊 RESUMEN\")\n",
        "\n",
        "    print(\"Total:\", total)\n",
        "\n",
        "    print(\"Completadas:\", completadas)\n",
        "\n",
        "    print(\"Pendientes:\", pendientes)\n",
        "\n",
        "\n",
        "def estadisticas(tareas):\n",
        "\n",
        "    completadas = len([t for t in tareas if t[\"completada\"]])\n",
        "\n",
        "    pendientes = len([t for t in tareas if not t[\"completada\"]])\n",
        "\n",
        "    print(\"\\n📈 ESTADÍSTICAS\")\n",
        "\n",
        "    print(\"Completadas:\", completadas)\n",
        "\n",
        "    print(\"Pendientes:\", pendientes)\n",
        "\n",
        "# =========================\n",
        "# MENÚ\n",
        "# =========================\n",
        "\n",
        "def menu():\n",
        "\n",
        "    print(\"\\n===== GESTOR DE TAREAS =====\")\n",
        "\n",
        "    print(\"1. Añadir tarea\")\n",
        "\n",
        "    print(\"2. Mostrar tareas\")\n",
        "\n",
        "    print(\"3. Completar tarea\")\n",
        "\n",
        "    print(\"4. Eliminar tarea\")\n",
        "\n",
        "    print(\"5. Buscar 🔍\")\n",
        "\n",
        "    print(\"6. Ver completadas ✅\")\n",
        "\n",
        "    print(\"7. Ver pendientes ⏳\")\n",
        "\n",
        "    print(\"8. Resumen 📊\")\n",
        "\n",
        "    print(\"9. Editar tarea ✏️\")\n",
        "\n",
        "    print(\"10. Completar todas\")\n",
        "\n",
        "    print(\"11. Limpiar completadas\")\n",
        "\n",
        "    print(\"12. Exportar tareas\")\n",
        "\n",
        "    print(\"13. Estadísticas\")\n",
        "\n",
        "    print(\"14. Salir\")\n",
        "\n",
        "# =========================\n",
        "# MAIN\n",
        "# =========================\n",
        "\n",
        "def main():\n",
        "\n",
        "    tareas = cargar_tareas()\n",
        "\n",
        "    while True:\n",
        "\n",
        "        menu()\n",
        "\n",
        "        opcion = input(\"Elige una opción: \")\n",
        "\n",
        "        if opcion == \"1\":\n",
        "\n",
        "            añadir_tarea(tareas)\n",
        "\n",
        "        elif opcion == \"2\":\n",
        "\n",
        "            mostrar_tareas(tareas)\n",
        "\n",
        "        elif opcion == \"3\":\n",
        "\n",
        "            completar_tarea(tareas)\n",
        "\n",
        "        elif opcion == \"4\":\n",
        "\n",
        "            eliminar_tarea(tareas)\n",
        "\n",
        "        elif opcion == \"5\":\n",
        "\n",
        "            buscar_tareas(tareas)\n",
        "\n",
        "        elif opcion == \"6\":\n",
        "\n",
        "            mostrar_completadas(tareas)\n",
        "\n",
        "        elif opcion == \"7\":\n",
        "\n",
        "            mostrar_pendientes(tareas)\n",
